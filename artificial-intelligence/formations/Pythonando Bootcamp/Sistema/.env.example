# Django
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco (SQLite por padrão; use DATABASE_URL para Postgres)
# DATABASE_URL=psql://user:pass@localhost:5432/jury_ai

# OpenAI (Documentos-IA, Chat-IA)
OPENAI_API_KEY=sk-proj-...

# CORS (se tiver front separado)
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Google Calendar (Bloco 4 - SecretariaAI / WhatsApp)
# Opção 1: caminho absoluto ao JSON baixado do Google Cloud (ex.: Downloads)
# GOOGLE_CREDENTIALS_PATH=/caminho/para/client_secret_xxx.apps.googleusercontent.com.json
# Opção 2: usar ID e chave e o app gera o JSON em credentials/
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# Token OAuth2 (gerado na primeira autorização)
# GOOGLE_CALENDAR_TOKEN_PATH=/caminho/para/token.json

# Evolution API (Bloco 4 - WhatsApp)
# URL da sua instância (ex.: Railway, self-hosted)
# EVOLUTION_API_URL=https://evolution-api-production-xxx.up.railway.app
# Chave da API (configurada na Evolution API)
# EVOLUTION_API_KEY=sua-api-key
# Nome da instância WhatsApp na Evolution API (ex.: default, Arcane3)
# EVOLUTION_INSTANCE=default
