              ],
              "body": "{\n  \"id\": 1,\n  \"nome\": \"Cliente Postman\",\n  \"email\": \"cliente@postman.com\",\n  \"telefone\": \"11999999999\",\n  \"cpf_cnpj\": \"\",\n  \"observacoes\": \"\",\n  \"criado_em\": \"2026-02-07T18:00:00Z\",\n  \"atualizado_em\": \"2026-02-07T18:00:00Z\"\n}"
            }
