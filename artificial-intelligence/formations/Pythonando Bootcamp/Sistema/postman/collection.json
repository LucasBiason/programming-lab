        {
          "name": "Delete Cliente",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/clientes/{{cliente_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "clientes", "{{cliente_id}}", ""],
              "variable": [
                {
                  "key": "cliente_id",
                  "value": "1",
                  "description": "ID do cliente a excluir"
